{
  "name": "crm-socket-server",
  "version": "1.0.0",
  "private": true,
  "description": "Servidor Socket.io standalone para realtime do CRM-Pro. Usa PostgreSQL LISTEN/NOTIFY como backend de pub/sub.",
  "scripts": {
    "dev": "tsx watch index.ts",
    "start": "node --import tsx index.ts",
    "build": "tsc"
  },
  "dependencies": {
    "socket.io": "^4.8.1",
    "pg": "^8.13.1",
    "dotenv": "^16.4.7",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/cors": "^2.8.17"
  }
}
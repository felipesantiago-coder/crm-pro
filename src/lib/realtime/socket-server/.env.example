# ═══════════════════════════════════════════════════════════════════
# CRM-PRO SOCKET.IO SERVER — Configuração
# ═══════════════════════════════════════════════════════════════════
# Copie este arquivo para .env e preencha os valores.
# ═══════════════════════════════════════════════════════════════════

# Connection string do PostgreSQL (a MESMA do Vercel / Supabase / Neon)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# URL base da API do CRM (para validar sessões NextAuth)
CRM_API_URL=https://seu-crm.vercel.app

# Porta do servidor Socket.io
PORT=3001

# Segredo para autenticação de integrações/sistemas (opcional)
# Se não definido, apenas sessões NextAuth são aceitas
# SOCKET_SECRET=um-segredo-bem-seguro-aqui

# Origens permitidas para CORS (separado por vírgula)
# Use * para development, ou liste as origens em produção
CORS_ORIGIN=*
# CORS_ORIGIN=https://seu-crm.vercel.app,https://seu-crm.com
generator client {
  provider = "prisma-client-js"
}

// === PRODUÇÃO (Vercel + Supabase PostgreSQL) ===
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id                String    @id @default(cuid()) @map("id")
  name              String    @map("name")
  phone             String?   @map("phone")
  email             String?   @map("email")
  region            String?   @map("region")
  enterprise        String?   @map("enterprise")
  enterpriseId      String?   @map("enterpriseId")
  notes             String?   @map("notes")
  updatePeriod      Int       @default(30) @map("updatePeriod")
  stage             String    @default("LEAD") @map("stage")
  lastInteractionAt DateTime? @map("lastInteractionAt")
  createdBy         String    @map("createdBy")
  createdAt         DateTime  @default(now()) @map("createdAt")
  updatedAt         DateTime  @updatedAt @map("updatedAt")
  utmSource         String?   @map("utmSource")
  utmMedium         String?   @map("utmMedium")
  utmCampaign       String?   @map("utmCampaign")
  utmContent        String?   @map("utmContent")
  utmTerm           String?   @map("utmTerm")

  tags         ClientTag[]
  reminders    Reminder[]
  interactions Interaction[]
  schedules    Schedule[]
  partners     ClientPartner[]
  linkedEnterprise Enterprise? @relation(fields: [enterpriseId], references: [id], onDelete: SetNull)
  creator      User          @relation("CreatedClients", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([createdBy])
  @@index([stage])
  @@index([region])
  @@index([enterpriseId])
  @@index([utmCampaign])
  @@index([phone])
  @@index([email])
  @@index([name])
  @@index([createdAt(sort: Desc)])
  @@index([lastInteractionAt])
  @@index([enterprise])
  @@index([updatePeriod])
  @@map("clients")
}

model Interaction {
  id          String   @id @default(cuid()) @map("id")
  description String   @map("description")
  clientId  String   @map("clientId")
  createdAt DateTime @default(now()) @map("createdAt")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([createdAt])
  @@map("interactions")
}

model Tag {
  id        String   @id @default(cuid()) @map("id")
  name      String   @unique @map("name")
  color     String   @default("#6366f1") @map("color")
  createdAt DateTime @default(now()) @map("createdAt")

  clients ClientTag[]

  @@map("tags")
}

model ClientTag {
  id        String   @id @default(cuid()) @map("id")
  clientId  String   @map("clientId")
  tagId     String   @map("tagId")
  createdAt DateTime @default(now()) @map("createdAt")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([clientId, tagId])
  @@map("client_tags")
}

model Reminder {
  id                    String   @id @default(cuid()) @map("id")
  title                 String   @map("title")
  description           String?  @map("description")
  dueDate               DateTime  @map("dueDate")
  dueTime               String?  @map("dueTime")
  notified              Boolean  @default(false) @map("notified")
  googleCalendarEventId String?  @map("googleCalendarEventId")
  clientId              String   @map("clientId")
  createdAt             DateTime  @default(now()) @map("createdAt")
  updatedAt             DateTime  @updatedAt @map("updatedAt")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([dueDate])
  @@index([notified, dueDate])
  @@index([notified])
  @@map("reminders")
}

model Enterprise {
  id                String   @id @default(cuid()) @map("id")
  name              String   @map("name")
  slug              String?  @unique @map("slug")
  region            String?  @map("region")
  imageUrl          String?  @map("imageUrl")
  pdfContent        String?  @map("pdfContent")
  landingTitle      String?  @map("landingTitle")
  landingSubtitle   String?  @map("landingSubtitle")
  landingDescription String? @map("landingDescription")
  cachedInfo        Json?    @map("cachedInfo")
  createdAt         DateTime @default(now()) @map("createdAt")
  updatedAt         DateTime @updatedAt @map("updatedAt")

  clients     Client[]
  images      EnterpriseImage[]
  formFields  LandingFormField[]

  @@index([name])
  @@index([region])
  @@map("enterprises")
}

model EnterpriseImage {
  id        String  @id @default(cuid()) @map("id")
  url       String  @map("url")
  altText   String? @map("altText")
  sortOrder Int     @default(0) @map("sortOrder")
  enterpriseId String @map("enterpriseId")
  createdAt  DateTime @default(now()) @map("createdAt")

  enterprise Enterprise @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)

  @@index([enterpriseId])
  @@index([sortOrder])
  @@map("enterprise_images")
}

model User {
  id                String   @id @default(cuid()) @map("id")
  name              String   @map("name")
  email             String   @unique @map("email")
  phone             String?  @map("phone")
  passwordHash      String   @map("passwordHash")
  role              String   @default("USER") @map("role")
  mustChangePassword Boolean @default(false) @map("mustChangePassword")
  telegramChatId    String?  @unique @map("telegramChatId")
  ntfyTopic         String?  @unique @map("ntfyTopic")
  ntfyToken         String?  @map("ntfyToken")
  passwordResetToken String?  @map("passwordResetToken")
  passwordResetExpires DateTime? @map("passwordResetExpires")
  createdAt         DateTime  @default(now()) @map("createdAt")
  updatedAt         DateTime  @updatedAt @map("updatedAt")

  createdClients      Client[]              @relation("CreatedClients")
  createdSchedules    Schedule[]           @relation("CreatedSchedules")
  partnerOf           ClientPartner[]
  addedPartners       ClientPartner[]      @relation("AddedPartners")
  googleCalendarToken GoogleCalendarToken?
  queueMemberships    LeadQueueMember[]
  queueAssignments    LeadQueueAssignment[]

  @@map("users")
}

model ClientPartner {
  id        String   @id @default(cuid()) @map("id")
  clientId  String   @map("clientId")
  userId    String   @map("userId")
  addedBy   String   @map("addedBy")
  createdAt DateTime @default(now()) @map("createdAt")

  client     Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  addedByUser User   @relation("AddedPartners", fields: [addedBy], references: [id])

  @@unique([clientId, userId])
  @@index([userId])
  @@map("client_partners")
}

model UserSettings {
  id        String   @id @default(cuid()) @map("id")
  key       String   @unique @map("key")
  value     String   @map("value")
  updatedAt DateTime  @updatedAt @map("updatedAt")

  @@map("user_settings")
}

model Schedule {
  id            String    @id @default(cuid()) @map("id")
  scheduledDate DateTime  @map("scheduledDate")
  scheduledTime        String   @map("scheduledTime")
  description           String?  @map("description")
  status                String   @default("PENDING") @map("status")
  completedAt           DateTime? @map("completedAt")
  clientId              String   @map("clientId")
  createdBy             String   @map("createdBy")
  googleCalendarEventId String?  @map("googleCalendarEventId")
  createdAt     DateTime  @default(now()) @map("createdAt")
  updatedAt     DateTime  @updatedAt @map("updatedAt")

  client      Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  creatorUser User   @relation("CreatedSchedules", fields: [createdBy], references: [id])

  @@index([clientId])
  @@index([status])
  @@index([scheduledDate])
  @@index([createdBy])
  @@map("schedules")
}

// ============================================================
// TRACKING PIXEL — Visitor & Event tracking
// ============================================================
model TrackingVisitor {
  id          String   @id @default(cuid()) @map("id")
  visitorId   String   @unique @map("visitorId")
  siteId      String   @map("siteId")
  leadId      String?  @map("leadId")
  firstSeenAt DateTime @default(now()) @map("firstSeenAt")
  lastSeenAt  DateTime @updatedAt @map("lastSeenAt")
  ip          String?  @map("ip")
  userAgent   String?  @map("userAgent")
  country     String?  @map("country")
  city        String?  @map("city")
  events      TrackingEvent[]
  @@index([siteId])
  @@index([leadId])
  @@index([lastSeenAt])
  @@map("tracking_visitors")
}

model TrackingEvent {
  id          String   @id @default(cuid()) @map("id")
  visitorId   String   @map("visitorId")
  sessionId   String   @map("sessionId")
  siteId      String   @map("siteId")
  eventType   String   @map("eventType")
  eventName   String?  @map("eventName")
  pageUrl     String?  @map("pageUrl")
  referrer    String?  @map("referrer")
  utmSource   String?  @map("utmSource")
  utmMedium   String?  @map("utmMedium")
  utmCampaign String?  @map("utmCampaign")
  utmContent  String?  @map("utmContent")
  utmTerm     String?  @map("utmTerm")
  metadata    Json?    @map("metadata")
  createdAt   DateTime @default(now()) @map("createdAt")
  visitor     TrackingVisitor @relation(fields: [visitorId], references: [visitorId], onDelete: Cascade)
  @@index([siteId, eventType])
  @@index([siteId, utmCampaign])
  @@index([visitorId])
  @@index([sessionId])
  @@index([createdAt])
  @@map("tracking_events")
}

// ============================================================
// LEAD QUEUE — Round-robin lead distribution for ad campaigns
// ============================================================
model LeadQueue {
  id          String   @id @default(cuid()) @map("id")
  name        String   @map("name")
  description String?  @map("description")
  isActive    Boolean  @default(true) @map("isActive")
  isDefault   Boolean  @default(false) @map("isDefault")
  currentIdx  Int      @default(0) @map("currentIdx")
  createdAt   DateTime @default(now()) @map("createdAt")
  updatedAt   DateTime @updatedAt @map("updatedAt")

  members     LeadQueueMember[]
  assignments LeadQueueAssignment[]

  @@map("lead_queues")
}

model LeadQueueMember {
  id       String  @id @default(cuid()) @map("id")
  queueId  String  @map("queueId")
  userId   String  @map("userId")
  order    Int     @default(0) @map("order")
  isActive Boolean @default(true) @map("isActive")

  queue LeadQueue @relation(fields: [queueId], references: [id], onDelete: Cascade)
  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([queueId, userId])
  @@index([queueId])
  @@map("lead_queue_members")
}

model LeadQueueAssignment {
  id        String   @id @default(cuid()) @map("id")
  queueId   String   @map("queueId")
  userId    String   @map("userId")
  leadId    String?  @map("leadId")
  source    String   @map("source")
  createdAt DateTime @default(now()) @map("createdAt")

  queue LeadQueue @relation(fields: [queueId], references: [id], onDelete: Cascade)
  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([queueId, createdAt])
  @@index([userId])
  @@index([leadId])
  @@map("lead_queue_assignments")
}

model GoogleCalendarToken {
  id           String   @id @default(cuid()) @map("id")
  userId       String   @unique @map("userId")
  accessToken  String   @map("accessToken")
  refreshToken String   @map("refreshToken")
  expiresAt    DateTime @map("expiresAt")
  createdAt    DateTime @default(now()) @map("createdAt")
  updatedAt    DateTime @updatedAt @map("updatedAt")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("google_calendar_tokens")
}

model LandingFormField {
  id           String   @id @default(cuid()) @map("id")
  enterpriseId String   @map("enterpriseId")
  label        String   @map("label")
  fieldType    String   @default("text") @map("fieldType")   // text | textarea | select | number | checkbox
  placeholder  String?  @map("placeholder")
  options      String?  @map("options")                        // JSON array for select fields
  required     Boolean  @default(false) @map("required")
  sortOrder    Int      @default(0) @map("sortOrder")
  isActive     Boolean  @default(true) @map("isActive")
  createdAt    DateTime @default(now()) @map("createdAt")
  updatedAt    DateTime @updatedAt @map("updatedAt")

  enterprise Enterprise @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)

  @@index([enterpriseId])
  @@map("landing_form_fields")
}

generator client {
  provider = "prisma-client-js"
}

// === PRODUÇÃO (Vercel + Supabase PostgreSQL) ===
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id                String    @id @default(cuid()) @map("id")
  name              String    @map("name")
  phone             String?   @map("phone")
  email             String?   @map("email")
  region            String?   @map("region")
  enterprise        String?   @map("enterprise")
  enterpriseId      String?   @map("enterpriseId")
  notes             String?   @map("notes")
  updatePeriod      Int       @default(30) @map("updatePeriod")
  lastInteractionAt DateTime? @map("lastInteractionAt")
  createdAt         DateTime  @default(now()) @map("createdAt")
  updatedAt         DateTime  @updatedAt @map("updatedAt")

  tags         ClientTag[]
  reminders    Reminder[]
  interactions Interaction[]
  linkedEnterprise Enterprise? @relation(fields: [enterpriseId], references: [id], onDelete: SetNull)

  @@map("clients")
}

model Interaction {
  id          String   @id @default(cuid()) @map("id")
  description String   @map("description")
  "clientId"  String   @map("clientId")
  "createdAt" DateTime @default(now()) @map("createdAt")

  client Client @relation(fields: ["clientId"], references: [id], onDelete: Cascade)

  @@map("interactions")
}

model Tag {
  id        String   @id @default(cuid()) @map("id")
  name      String   @unique @map("name")
  color     String   @default("#6366f1") @map("color")
  createdAt DateTime @default(now()) @map("createdAt")

  clients ClientTag[]

  @@map("tags")
}

model ClientTag {
  id        String   @id @default(cuid()) @map("id")
  clientId  String   @map("clientId")
  tagId     String   @map("tagId")
  createdAt DateTime @default(now()) @map("createdAt")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([clientId, tagId])
  @@map("client_tags")
}

model Reminder {
  id          String   @id @default(cuid()) @map("id")
  title       String   @map("title")
  description String?  @map("description")
  dueDate     DateTime  @map("dueDate")
  notified    Boolean  @default(false) @map("notified")
  clientId    String   @map("clientId")
  createdAt   DateTime  @default(now()) @map("createdAt")
  updatedAt   DateTime  @updatedAt @map("updatedAt")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("reminders")
}

model Enterprise {
  id        String   @id @default(cuid()) @map("id")
  name      String   @map("name")
  region    String?  @map("region")
  imageUrl  String?  @map("imageUrl")
  createdAt DateTime  @default(now()) @map("createdAt")
  updatedAt DateTime  @updatedAt @map("updatedAt")

  clients Client[]

  @@map("enterprises")
}

model User {
  id                String   @id @default(cuid()) @map("id")
  name              String   @map("name")
  email             String   @unique @map("email")
  passwordHash      String   @map("passwordHash")
  role              String   @default("USER") @map("role")
  mustChangePassword Boolean @default(false) @map("mustChangePassword")
  createdAt         DateTime  @default(now()) @map("createdAt")
  updatedAt         DateTime  @updatedAt @map("updatedAt")

  @@map("users")
}

model UserSettings {
  id        String   @id @default(cuid()) @map("id")
  key       String   @unique @map("key")
  value     String   @map("value")
  updatedAt DateTime  @updatedAt @map("updatedAt")

  @@map("user_settings")
}

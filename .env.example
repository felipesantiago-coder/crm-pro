# CRM Pro - Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores do seu projeto Supabase

# =============================================================
# SUPABASE (Produção - Vercel)
# =============================================================
# Obtenha estas credenciais em: https://supabase.com/dashboard → Seu Projeto → Settings → API
#
# URL do projeto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
#
# Chave anônima (anon/public key) - segura para uso no frontend
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui
#
# DATABASE_URL - String de conexão PostgreSQL direta
# Formato para connection pooling (recomendado para Vercel):
DATABASE_URL=postgresql://postgres.seu-projeto:[SENHA]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
#
# Alternativa: conexão direta (sem pooling):
# DATABASE_URL=postgresql://postgres:[SENHA]@db.seu-projeto.supabase.co:5432/postgres

# =============================================================
# DESENVOLVIMENTO LOCAL (SQLite)
# =============================================================
# Para rodar localmente com SQLite, use as linhas abaixo
# e comente o bloco de Supabase acima.
# E também altere o provider em prisma/schema.prisma para "sqlite"
#
# DATABASE_URL=file:./db/custom.db

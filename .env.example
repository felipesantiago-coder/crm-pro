# CRM Pro - Variáveis de Ambiente
# Copie este arquivo para .env.local (Vercel) ou .env (local) e preencha os valores

# =============================================================
# SUPABASE (Produção - Vercel)
# =============================================================
# Obtenha estas credenciais em: https://supabase.com/dashboard → Seu Projeto → Settings → API
#
# URL do projeto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
#
# Chave anônima (anon/public key) - segura para uso no frontend
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui
#
# DATABASE_URL - String de conexão PostgreSQL direta
# Formato para connection pooling (recomendado para Vercel):
DATABASE_URL=postgresql://postgres.seu-projeto:[SENHA]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
#
# Alternativa: conexão direta (sem pooling):
# DATABASE_URL=postgresql://postgres:[SENHA]@db.seu-projeto.supabase.co:5432/postgres

# =============================================================
# AUTENTICAÇÃO (NextAuth)
# =============================================================
# Chave secreta para JWT - gere uma string aleatória segura (mínimo 32 caracteres)
# Comando: openssl rand -base64 32
NEXTAUTH_SECRET=sua-chave-secreta-aqui

# =============================================================
# E-MAIL (Resend)
# =============================================================
# Crie uma conta gratuita em: https://resend.com
# Free tier: 100 e-mails/dia, 3.000 e-mails/mês
#
# Chave API do Resend
RESEND_API_KEY=re_xxxxx
#
# E-mail remetente (deve estar verificado no Resend)
NOTIFICATION_FROM_EMAIL=CRM Pro <noreply@seu-dominio.com>
#
# URL base da aplicação (para links nos e-mails)
NEXT_PUBLIC_APP_URL=https://seu-crm.vercel.app

# =============================================================
# WHATSAPP (Meta Cloud API - WhatsApp Business Platform)
# =============================================================
# Configuração da API oficial do WhatsApp Business da Meta.
# Grátis para mensagens dentro da janela de 24h (respostas).
# Para notificações proativas, usa template messages (custo ~US$ 0,01/msg).
#
# PASSO 1: Crie uma conta no Meta Business Manager
#   https://business.facebook.com/settings/
#
# PASSO 2: Adicione o WhatsApp à sua conta de negócios
#   https://business.facebook.com/wa/manage/
#
# PASSO 3: Crie um App no Meta for Developers e solicite
#   acesso à WhatsApp Business API
#   https://developers.facebook.com/apps/
#
# PASSO 4: Gere um System User Token com permissões:
#   - whatsapp_business_messaging
#   - whatsapp_business_management
#
# PASSO 5: Obtenha o Phone Number ID na aba do WhatsApp Business
#
# --- Credenciais ---
#
# Token de acesso permanente (System User Token)
WHATSAPP_ACCESS_TOKEN=EAAXxxxxx
#
# ID do número de telefone do WhatsApp Business
WHATSAPP_PHONE_NUMBER_ID=1234567890
#
# Versão da Graph API (opcional, default: v21.0)
# WHATSAPP_VERSION=v21.0
#
# --- Templates de Mensagem ---
# Crie os seguintes templates no Meta Business Manager:
# https://business.facebook.com/wa/manage/message-templates/
#
# 1. crm_visita_agendada
#    Categoria: UTILITY
#    Body: Uma visita foi agendada para o cliente {{1}} no dia {{2}} às {{3}}, agendado por {{4}}.{{5}}
#
# 2. crm_lembrete_vencido
#    Categoria: UTILITY
#    Body: Um lembrete venceu para o cliente {{1}}: {{2}}. Vencimento: {{3}}.{{4}}
#
# 3. crm_novo_parceiro
#    Categoria: UTILITY
#    Body: {{1}} foi adicionado como parceiro do cliente {{2}} por {{3}}.
#
# 4. crm_nova_observacao
#    Categoria: UTILITY
#    Body: Nova observação registrada no cliente {{1}}: {{2}}
#
# 5. crm_visita_proxima
#    Categoria: UTILITY
#    Body: Lembrete: você tem uma visita agendada hoje às {{1}} para o cliente {{2}}.

# =============================================================
# CRON JOB (Vercel)
# =============================================================
# Chave secreta para proteger o endpoint do cron
# Gere com: openssl rand -base64 32
CRON_SECRET=sua-cron-secret-aqui

# =============================================================
# DESENVOLVIMENTO LOCAL (SQLite)
# =============================================================
# Para rodar localmente com SQLite, use a linha abaixo
# e comente o bloco de Supabase acima.
# Também altere o provider em prisma/schema.prisma para "sqlite"
#
# DATABASE_URL=file:./db/custom.db
